{
  "expo": {
    "name": "CareerForge",
    "slug": "career-forge",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "info.chihho.careerforge"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "info.chihho.careerforge"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-document-picker"
    ],
    "scheme": "career-forge"
  }
}